      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "hasAssociation"
      },
      "value": {
        "value": "For social and professional ties only. Use dedicated family properties (hasParent, hasChild, hasSibling, hasSpouse) for kinship relations.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "LifeEvent"
      },
      "value": {
        "value": "Abstract superclass for biographical events. Do not instantiate directly; use specific subclasses (Birth, Death, Education, etc.).",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "hasSpouse"
      },
      "value": {
        "value": "Derived via property chain: hasEvent o marriedTo -> hasSpouse. Do not assert directly.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "hasGrandparent"
      },
      "value": {
        "value": "Derived via property chain: hasParent o hasParent -> hasGrandparent. Do not assert directly.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "hasAuntOrUncle"
      },
      "value": {
        "value": "Derived via property chain: hasParent o hasSibling -> hasAuntOrUncle. Do not assert directly.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "hasSibling"
      },
      "value": {
        "value": "Directly asserted only. No property chain (hasParent o hasChild would cause self-sibling inference).",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "MarriedPerson"
      },
      "value": {
        "value": "Means 'ever married', not 'currently married'. Temporal distinction requires reasoning beyond OWL 2 EL.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "partOf"
      },
      "value": {
        "value": "Transitive mereological relation. Used for both Place and Organization hierarchies. No domain/range restriction.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "marriedTo"
      },
      "value": {
        "value": "Spouse role within a Marriage event. Sub-property of withPerson. Used in property chain to derive hasSpouse.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "Person"
      },
      "value": {
        "value": "A human individual whose biographical data is being represented.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "Place"
      },
      "value": {
        "value": "A geographic location. Use partOf for hierarchical relations (e.g., city partOf country).",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "Organization"
      },
      "value": {
        "value": "An institution, company, military unit, religious order, or other organized body. Use partOf for organizational hierarchy.",
        "lang": "en"
      }
    },
    {
      "type": "AnnotationAssertion",
      "property": {
        "prefix": "rdfs",
        "local_name": "comment"
      },
      "subject": {
        "prefix": "",
        "local_name": "Relationship"
      },
      "value": {
        "value": "A reified social or professional tie between persons. Not for family relations.",
        "lang": "en"
      }
    }
